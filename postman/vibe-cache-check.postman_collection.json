{
  "info": {
    "_postman_id": "f9df59a2-ddd0-438f-af92-af01fe80bb8a",
    "name": "Vibe Cache Check",
    "description": "Checks whether cached CV is reused between story fetches.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "laravel_base_url",
      "value": "http://206.189.107.5:8000"
    },
    {
      "key": "story_slug",
      "value": "home"
    },
    {
      "key": "cv_latest_after_cold",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "A) Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/health",
          "host": [
            "{{laravel_base_url}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "B) Clear CV Cache",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source\": \"postman-cache-check\",\n  \"invalidate\": \"slug\",\n  \"slug\": \"{{story_slug}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{laravel_base_url}}/api/story/cache/clear",
          "host": [
            "{{laravel_base_url}}"
          ],
          "path": [
            "api",
            "story",
            "cache",
            "clear"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Clear returns cv', function () {",
              "  pm.expect(json.cv).to.exist;",
              "});",
              "pm.test('Clear invalidates by slug', function () {",
              "  pm.expect(json.invalidate).to.eql('slug');",
              "  pm.expect(json.slug).to.exist;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "C) Story Fetch (cold)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/story?slug={{story_slug}}",
          "host": [
            "{{laravel_base_url}}"
          ],
          "path": [
            "api",
            "story"
          ],
          "query": [
            {
              "key": "slug",
              "value": "{{story_slug}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Contains cv.latest', function () {",
              "  pm.expect(json.cv).to.be.an('object');",
              "  pm.expect(json.cv.latest).to.exist;",
              "});",
              "pm.collectionVariables.set('cv_latest_after_cold', String(json.cv.latest || ''));"
            ]
          }
        }
      ]
    },
    {
      "name": "D) Check if cached (warm)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/story?slug={{story_slug}}",
          "host": [
            "{{laravel_base_url}}"
          ],
          "path": [
            "api",
            "story"
          ],
          "query": [
            {
              "key": "slug",
              "value": "{{story_slug}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "const cvLatestAfterCold = pm.collectionVariables.get('cv_latest_after_cold');",
              "pm.test('Warm fetch includes cv.used', function () {",
              "  pm.expect(json.cv).to.be.an('object');",
              "  pm.expect(json.cv.used).to.exist;",
              "});",
              "pm.test('Warm fetch reused cached cv', function () {",
              "  pm.expect(String(json.cv.used)).to.eql(String(cvLatestAfterCold));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "E) Webhook invalidation (slug)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"published\",\n  \"space_id\": 123456,\n  \"story\": {\n    \"full_slug\": \"{{story_slug}}\"\n  },\n  \"invalidate\": \"slug\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{laravel_base_url}}/api/storyblok/webhook",
          "host": [
            "{{laravel_base_url}}"
          ],
          "path": [
            "api",
            "storyblok",
            "webhook"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Webhook invalidates by slug', function () {",
              "  pm.expect(json.invalidate).to.eql('slug');",
              "});",
              "pm.test('Webhook keeps slug', function () {",
              "  pm.expect(json.slug).to.exist;",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
