{
  "info": {
    "_postman_id": "a8e79ac2-2633-4d23-a7da-0f0944fde1a9",
    "name": "Vibe Backend Direct Fetch",
    "description": "Direct Laravel backend workflow for health, story fetch, slug invalidation, and webhook handling.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "laravel_base_url", "value": "http://206.189.107.5:8000" },
    { "key": "home_slug", "value": "home" },
    { "key": "about_slug", "value": "about" },
    { "key": "home_cv_latest_before_about_invalidation", "value": "" }
  ],
  "item": [
    {
      "name": "A) Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/health",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "health"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "pm.test('Health payload has status ok', function () {",
            "  pm.expect(json.status).to.eql('ok');",
            "});"
          ]
        }
      }]
    },
    {
      "name": "B) Home fetch (cold)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/story?slug={{home_slug}}",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "story"],
          "query": [{ "key": "slug", "value": "{{home_slug}}" }]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "pm.test('Home response includes cv.latest', function () {",
            "  pm.expect(json.cv).to.be.an('object');",
            "  pm.expect(json.cv.latest).to.exist;",
            "});",
            "pm.collectionVariables.set('home_cv_latest_before_about_invalidation', String(json.cv.latest || ''));"
          ]
        }
      }]
    },
    {
      "name": "C) Home fetch (warm)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/story?slug={{home_slug}}",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "story"],
          "query": [{ "key": "slug", "value": "{{home_slug}}" }]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "const stored = pm.collectionVariables.get('home_cv_latest_before_about_invalidation');",
            "pm.test('Warm home uses cached cv', function () {",
            "  pm.expect(json.cv).to.be.an('object');",
            "  pm.expect(String(json.cv.used)).to.eql(String(stored));",
            "});"
          ]
        }
      }]
    },
    {
      "name": "D) About fetch",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/story?slug={{about_slug}}",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "story"],
          "query": [{ "key": "slug", "value": "{{about_slug}}" }]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "pm.test('About response includes story and cv', function () {",
            "  pm.expect(json.story).to.exist;",
            "  pm.expect(json.cv).to.be.an('object');",
            "});"
          ]
        }
      }]
    },
    {
      "name": "E) Clear about slug (backend)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source\": \"postman-backend-direct\",\n  \"slug\": \"{{about_slug}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{laravel_base_url}}/api/story/cache/clear",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "story", "cache", "clear"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "pm.test('Clear response uses slug invalidation', function () {",
            "  pm.expect(json.invalidate).to.eql('slug');",
            "  pm.expect(json.slug).to.eql(pm.collectionVariables.get('about_slug'));",
            "});",
            "pm.test('Clear response includes cv', function () {",
            "  pm.expect(json.cv).to.exist;",
            "});"
          ]
        }
      }]
    },
    {
      "name": "F) Home still warm after about clear",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{laravel_base_url}}/api/story?slug={{home_slug}}",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "story"],
          "query": [{ "key": "slug", "value": "{{home_slug}}" }]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "const stored = pm.collectionVariables.get('home_cv_latest_before_about_invalidation');",
            "pm.test('Home still uses same cached cv', function () {",
            "  pm.expect(json.cv).to.be.an('object');",
            "  pm.expect(String(json.cv.used)).to.eql(String(stored));",
            "});"
          ]
        }
      }]
    },
    {
      "name": "G) Webhook invalidation (slug)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"published\",\n  \"space_id\": 123456,\n  \"story\": {\n    \"full_slug\": \"{{about_slug}}\"\n  },\n  \"invalidate\": \"slug\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{laravel_base_url}}/api/storyblok/webhook",
          "host": ["{{laravel_base_url}}"],
          "path": ["api", "storyblok", "webhook"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "pm.test('Status is 200', function () {",
            "  pm.response.to.have.status(200);",
            "});",
            "const json = pm.response.json();",
            "pm.test('Webhook response uses slug invalidation', function () {",
            "  pm.expect(json.invalidate).to.eql('slug');",
            "  pm.expect(json.slug).to.eql(pm.collectionVariables.get('about_slug'));",
            "});"
          ]
        }
      }]
    }
  ]
}
